@model IEnumerable<ABCRETAILSTORE.Models.ProductEntity>
@{
    ViewData["Title"] = "Products";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-box-seam"></i> @ViewData["Title"] (SQL Database)</h2>
    </div>

    <div class="row g-4">
        @foreach (var product in Model)
        {
            <div class="col-md-4">
                <div class="card h-100 shadow-sm">
                    <img src="@(product.ImageUrl ?? "https://via.placeholder.com/150.png")" class="card-img-top" alt="@product.Name" style="height: 200px; object-fit: cover;">
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">@product.Name</h5>
                        <p class="card-text">@product.Description</p>
                        <p class="card-text fw-bold">Price: R @product.Price.ToString("N2")</p>
                        <p class="card-text"><small class="text-muted">Stock: @product.Stock</small></p>

                        <div class="mt-auto">
                            @if (product.Stock > 0)
                            {
                                <a asp-controller="ShoppingCart" asp-action="AddToCart" asp-route-id="@product.ProductSqlId" class="btn btn-primary w-100">
                                    <i class="bi bi-cart-plus"></i> Add to Cart
                                </a>
                            }
                            else
                            {
                                <a href="#" class="btn btn-secondary w-100 disabled">Out of Stock</a>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>