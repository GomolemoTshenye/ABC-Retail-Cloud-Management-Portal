@model IEnumerable<ABCRETAILSTORE.Models.Order>

@{
    ViewData["Title"] = "Order Management (Admin)";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-clipboard-check"></i> @ViewData["Title"]</h2>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <table class="table table-hover">
                <thead class="table-light">
                    <tr>
                        <th>Order ID</th>
                        <th>Customer</th>
                        <th>Order Date</th>
                        <th>Total</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in Model)
                    {
                        <tr>
                            <td>@order.Id</td>
                            <td>@order.User.Email</td>
                            <td>@order.OrderPlaced.ToString("yyyy-MM-dd HH:mm")</td>
                            <td>R @order.OrderTotal.ToString("N2")</td>
                            <td>
                                @if (order.Status == "Pending")
                                {
                                    <span class="badge bg-warning text-dark">@order.Status</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">@order.Status</span>
                                }
                            </td>
                            <td>
                                <a asp-action="Details" asp-route-id="@order.Id" class="btn btn-sm btn-outline-primary"><i class="bi bi-eye"></i> Details</a>
                                @if (order.Status == "Pending")
                                {
                                    <form asp-action="ProcessOrder" asp-route-id="@order.Id" method="post" class="d-inline" onsubmit="return confirm('Are you sure you want to mark this order as processed?');">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-success"><i class="bi bi-check-lg"></i> Process</button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>