@{
    ViewData["Title"] = "Upload Contract";
}

<div class="container mt-4">
    <h2><i class="bi bi-upload"></i> @ViewData["Title"]</h2>
    <hr />
    <div class="row">
        <div class="col-md-6">
            <form asp-action="Upload" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <div class="mb-3">
                    <label for="file" class="form-label">Select Contract File</label>
                    <input type="file" name="file" class="form-control" accept=".pdf,.doc,.docx,.txt" required />
                    <div class="form-text">Supported formats: PDF, DOC, DOCX, TXT</div>
                </div>
                <div class="mb-3">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-upload"></i> Upload
                    </button>
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="bi bi-arrow-left"></i> Back to List
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>