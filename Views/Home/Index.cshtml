@{
    ViewData["Title"] = "ABC Retail Cloud Portal";
}

<div class="container mt-5">
    <div class="text-center mb-5">
        <img src="data:image/jpeg;base64,." alt="ABC Retail Logo" class="mb-3" style="max-width: 200px;" />
        <h1 class="display-4 fw-bold">Welcome to ABC Retail</h1>
        <p class="lead">Your one-stop cloud solution for seamless retail management</p>
    </div>

    <div class="row g-4">
        <div class="col-md-3 col-sm-6">
            <div class="card dashboard-card h-100">
                <div class="card-body text-center">
                    <i class="bi bi-person-circle text-primary display-4 mb-3"></i>
                    <h5 class="card-title">Customer Management</h5>
                    <p class="card-text">Manage customer profiles and product data securely with Azure Table Storage.</p>
                    <a href="/Customer/Index" class="btn btn-primary btn-sm">Manage Customers</a>
                </div>
            </div>
        </div>

        <div class="col-md-3 col-sm-6">
            <div class="card dashboard-card h-100">
                <div class="card-body text-center">
                    <i class="bi bi-image text-primary display-4 mb-3"></i>
                    <h5 class="card-title">Product Media</h5>
                    <p class="card-text">Upload and showcase product images using Azure Blob Storage.</p>
                    <a href="/Storage/Products" class="btn btn-primary btn-sm">View POE 2 Products</a>
                </div>
            </div>
        </div>

        <div class="col-md-3 col-sm-6">
            <div class="card dashboard-card h-100">
                <div class="card-body text-center">
                    <i class="bi bi-cart-check text-primary display-4 mb-3"></i>
                    <h5 class="card-title">Order Processing</h5>
                    <p class="card-text">Streamline order tracking with Azure Queue Storage.</p>
                    <a href="/Storage/CreateOrder" class="btn btn-primary btn-sm">Queue Order</a>
                </div>
            </div>
        </div>

        <div class="col-md-3 col-sm-6">
            <div class="card dashboard-card h-100">
                <div class="card-body text-center">
                    <i class="bi bi-file-earmark-text text-primary display-4 mb-3"></i>
                    <h5 class="card-title">Contract Documents</h5>
                    <p class="card-text">Securely manage contracts with Azure File Storage.</p>
                    <a href="/Document/Index" class="btn btn-primary btn-sm">Manage Documents</a>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mt-3">
        <div class="col-12">
            <div class="card dashboard-card h-100">
                <div class="card-body text-center">
                    <i class="bi bi-shop text-primary display-4 mb-3"></i>
                    <h5 class="card-title">POE 3 SQL Product Store</h5>
                    <p class="card-text">Browse products, add to cart, and check out using our new SQL-powered store.</p>
                    <a href="/Products/Index" class="btn btn-primary btn-sm">Go to Store</a>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-5 text-center">
        <p class="text-muted">Empowering retail innovation with ABC Retail Cloud Solutions.</p>
        <p class="text-muted small">Built with ASP.NET Core MVC & Microsoft Azure Storage Services</p>
    </div>
</div>