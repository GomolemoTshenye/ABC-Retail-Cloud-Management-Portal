@model ABCRETAILSTORE.Models.ProductEntity
@using ABCRETAILSTORE.Models
@{
    ViewData["Title"] = "Create Product (POE 2)";
}

<div class="container mt-4">
    <h2 class="mb-3">
        <i class="bi bi-plus-circle"></i> @ViewData["Title"]
    </h2>
    <hr />
    <div class="row justify-content-center">
        <div class="col-md-6">
            <form asp-controller="Storage" asp-action="CreateProduct" enctype="multipart/form-data" method="post" class="border rounded p-4 shadow-sm bg-light">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                <div class="mb-3">
                    <label asp-for="Name" class="form-label"></label>
                    <input asp-for="Name" class="form-control" placeholder="Enter product name" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Description" class="form-label"></label>
                    <textarea asp-for="Description" class="form-control" placeholder="Enter product description"></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Price" class="form-label"></label>
                    <input asp-for="Price" class="form-control" type="number" step="0.01" placeholder="Enter price" />
                    <span asp-validation-for="Price" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Stock" class="form-label"></label>
                    <input asp-for="Stock" class="form-control" type="number" placeholder="Enter stock" />
                    <span asp-validation-for="Stock" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label class="form-label">Product Image (Blob)</label>
                    <input type="file" name="image" class="form-control" />
                </div>
                <div class="d-flex justify-content-between">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-save"></i> Save
                    </button>
                    <a asp-action="Products" class="btn btn-secondary">
                        <i class="bi bi-arrow-left"></i> Back to List
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>