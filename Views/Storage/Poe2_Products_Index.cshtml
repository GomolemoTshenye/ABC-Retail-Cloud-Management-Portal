@model IEnumerable<ABCRETAILSTORE.Models.ProductEntity>
@using ABCRETAILSTORE.Models
@{
    ViewData["Title"] = "Product Management (POE 2 - Table/Blob)";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-box-seam"></i> @ViewData["Title"]</h2>
        <a asp-action="CreateProduct" class="btn btn-primary me-2"><i class="bi bi-plus-circle"></i> Add Product</a>
    </div>
    <div class="card shadow-sm">
        <div class="card-body">
            <table class="table table-hover">
                <thead class="table-light">
                    <tr>
                        <th>Image (Blob)</th>
                        <th>Name (Table)</th>
                        <th>Description</th>
                        <th>Price (ZAR)</th>
                        <th>Stock</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var product in Model)
                    {
                        <tr>
                            <td>
                                @if (!string.IsNullOrEmpty(product.ImageUrl))
                                {
                                    <img src="@product.ImageUrl" alt="@product.Name" class="img-thumbnail" style="max-width: 80px; max-height: 80px;" />
                                }
                                else
                                {
                                    <span class="text-muted">No image</span>
                                }
                            </td>
                            <td>@product.Name</td>
                            <td>@product.Description</td>
                            <td>R @product.Price.ToString("N2")</td>
                            <td>@product.Stock</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>